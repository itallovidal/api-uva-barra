# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# JWT
JWT_SECRET=dev-secret

# Firebase — Service Account
# Obtenha esses valores do arquivo service-account-key.json baixado do Firebase Console.
# A FIREBASE_PRIVATE_KEY contém \n literais — mantenha entre aspas duplas.
# O código fará o replace de \n para newlines reais automaticamente.
#
# Exemplo:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQCy...\n-----END PRIVATE KEY-----\n"

FIREBASE_PROJECT_ID=seu-projeto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMII...\n-----END PRIVATE KEY-----\n"
